{
  "service": "wix-demo",
  "displayName": "Wix Demo — Local Mock Server",
  "version": "1.0",
  "hidden": true,

  "auth": {
    "type": "bearer",
    "keychainKey": "api2file.wix-demo.key",
    "setup": {
      "instructions": "No auth needed — this is a local demo server. Set any value."
    }
  },

  "globals": {
    "baseUrl": "http://localhost:8089",
    "headers": {
      "Content-Type": "application/json"
    }
  },

  "resources": [
    {
      "name": "contacts",
      "description": "Wix CRM contacts as a CSV spreadsheet",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/contacts", "dataPath": "$.contacts" },
      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "contacts.csv",
        "format": "csv",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "flatten", "path": "info.name", "to": "" },
            { "op": "flatten", "path": "info.emails", "to": "emails" },
            { "op": "flatten", "path": "info.phones", "to": "phones" },
            { "op": "omit", "fields": ["info", "revision", "source", "lastActivity"] }
          ]
        }
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "blog-posts",
      "description": "Wix blog posts as Markdown files",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/posts",
        "dataPath": "$.posts",
        "detail": {
          "method": "GET",
          "url": "http://localhost:8089/api/wix/posts/{id}",
          "dataPath": "$.post"
        }
      },
      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "blog",
        "filename": "{slug|slugify}.md",
        "format": "md",
        "formatOptions": {
          "fieldMapping": {
            "richContent": "richContent"
          }
        },
        "idField": "id",
        "contentField": "contentText"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "products",
      "description": "Wix Store products as a CSV catalog",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/products", "dataPath": "$.products" },
      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "products.csv",
        "format": "csv",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "media",
      "description": "Wix Media Manager files",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/media",
        "type": "media",
        "dataPath": "$.files",
        "mediaConfig": {
          "urlField": "url",
          "filenameField": "displayName",
          "idField": "id",
          "sizeField": "sizeInBytes",
          "hashField": "hash"
        }
      },
      "fileMapping": {
        "strategy": "mirror",
        "directory": "media",
        "format": "raw",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "pro-gallery",
      "description": "Media Manager images used by Pro Gallery",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/media",
        "type": "media",
        "dataPath": "$.files",
        "mediaConfig": {
          "urlField": "url",
          "filenameField": "displayName",
          "idField": "id",
          "sizeField": "sizeInBytes",
          "hashField": "hash"
        }
      },
      "fileMapping": {
        "strategy": "mirror",
        "directory": "pro-gallery",
        "format": "raw",
        "idField": "id",
        "transforms": { "pull": [{ "op": "match", "field": "mediaType", "value": "IMAGE" }] }
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "pdf-viewer",
      "description": "PDF documents stored in Media Manager",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/media",
        "type": "media",
        "dataPath": "$.files",
        "mediaConfig": {
          "urlField": "url",
          "filenameField": "displayName",
          "idField": "id",
          "sizeField": "sizeInBytes",
          "hashField": "hash"
        }
      },
      "fileMapping": {
        "strategy": "mirror",
        "directory": "pdf-viewer",
        "format": "raw",
        "idField": "id",
        "transforms": { "pull": [{ "op": "match", "field": "mimeType", "value": "application/pdf" }] }
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "wix-video",
      "description": "Video assets stored in Media Manager",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/media",
        "type": "media",
        "dataPath": "$.files",
        "mediaConfig": {
          "urlField": "url",
          "filenameField": "displayName",
          "idField": "id",
          "sizeField": "sizeInBytes",
          "hashField": "hash"
        }
      },
      "fileMapping": {
        "strategy": "mirror",
        "directory": "wix-video",
        "format": "raw",
        "idField": "id",
        "transforms": { "pull": [{ "op": "match", "field": "mediaType", "value": "VIDEO" }] }
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "wix-music-podcasts",
      "description": "Audio assets stored in Media Manager",
      "pull": {
        "method": "GET",
        "url": "http://localhost:8089/api/wix/media",
        "type": "media",
        "dataPath": "$.files",
        "mediaConfig": {
          "urlField": "url",
          "filenameField": "displayName",
          "idField": "id",
          "sizeField": "sizeInBytes",
          "hashField": "hash"
        }
      },
      "fileMapping": {
        "strategy": "mirror",
        "directory": "wix-music-podcasts",
        "format": "raw",
        "idField": "id",
        "transforms": { "pull": [{ "op": "match", "field": "mediaType", "value": "AUDIO" }] }
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "bookings-services",
      "description": "Wix Bookings services as a CSV spreadsheet",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/services", "dataPath": "$.services" },
      "fileMapping": {
        "strategy": "collection",
        "directory": "bookings",
        "filename": "services.csv",
        "format": "csv",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "bookings-appointments",
      "description": "Wix Bookings customer appointments and bookings",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/appointments", "dataPath": "$.bookings" },
      "fileMapping": {
        "strategy": "collection",
        "directory": "bookings",
        "filename": "appointments.csv",
        "format": "csv",
        "idField": "id",
        "readOnly": true
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "groups",
      "description": "Wix Groups as a CSV spreadsheet",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/groups", "dataPath": "$.groups" },
      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "groups.csv",
        "format": "csv",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "comments",
      "description": "Wix Comments as a CSV spreadsheet",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/comments", "dataPath": "$.comments" },
      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "comments.csv",
        "format": "csv",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "bookings",
      "description": "Wix Bookings services as JSON files",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/services", "dataPath": "$.services" },
      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "bookings",
        "filename": "{name|slugify}.json",
        "format": "json",
        "idField": "id"
      },
      "sync": { "interval": 10, "debounceMs": 500 }
    },
    {
      "name": "collections",
      "description": "Wix CMS data collections catalog",
      "pull": { "method": "GET", "url": "http://localhost:8089/api/wix/collections", "dataPath": "$.collections" },
      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "collections.json",
        "format": "json",
        "idField": "id"
      },
      "children": [
        {
          "name": "items",
          "description": "Items in this CMS collection",
          "pull": {
            "method": "GET",
            "url": "http://localhost:8089/api/wix/collections/{id}/items",
            "dataPath": "$.dataItems"
          },
          "fileMapping": {
            "strategy": "collection",
            "directory": "cms",
            "filename": "{displayName|slugify}.csv",
            "format": "csv",
            "idField": "id"
          }
        }
      ],
      "sync": { "interval": 10, "debounceMs": 500 }
    }
  ]
}

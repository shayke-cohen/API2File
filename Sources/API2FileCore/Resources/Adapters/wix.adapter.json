        "body": {
          "appId": "14bcded7-0066-7c35-14d7-466cb3f09103",
          "query": {
            "paging": {
              "limit": 100
            }
          }
        },
        "dataPath": "$.comments"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/comments/v1/comments",
          "bodyWrapper": "comment"
        },
        "update": {
          "method": "PATCH",

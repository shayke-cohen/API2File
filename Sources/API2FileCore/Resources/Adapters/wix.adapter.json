{
  "service": "wix",
  "displayName": "Wix — Website & Business Platform",
  "version": "1.0",
  "icon": "globe",
  "wizardDescription": "Contacts, products, blog posts, bookings",
  "siteUrl": "YOUR_SITE_URL_HERE",
  "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/home",
  "setupFields": [
    {
      "key": "wix-site-id",
      "label": "Site ID",
      "placeholder": "abc123-def456-...",
      "templateKey": "YOUR_SITE_ID_HERE",
      "helpText": "Find in your Wix dashboard URL after /dashboard/"
    },
    {
      "key": "wix-site-url",
      "label": "Site URL",
      "placeholder": "https://username.wixsite.com/mysite",
      "templateKey": "YOUR_SITE_URL_HERE",
      "helpText": "Your published Wix site URL (from browser address bar)"
    }
  ],

  "auth": {
    "type": "apiKey",
    "keychainKey": "api2file.wix.key",
    "setup": {
      "instructions": "1. Go to dev.wix.com → API Keys → Generate API Key. 2. Copy your Site ID from the Wix dashboard URL. 3. After connecting, edit ~/API2File/wix/.api2file/adapter.json and set your wix-site-id in globals.headers.",
      "url": "https://dev.wix.com/apps"
    }
  },

  "globals": {
    "baseUrl": "https://www.wixapis.com",
    "headers": {
      "Content-Type": "application/json",
      "wix-site-id": "YOUR_SITE_ID_HERE"
    }
  },

  "resources": [
    {
      "name": "contacts",
      "description": "Wix CRM contacts as a CSV spreadsheet",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/contacts",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/contacts/v4/contacts/query",
        "body": {
          "query": {
            "paging": {
              "limit": 100
            }
          }
        },
        "dataPath": "$.contacts",
        "updatedSinceBodyPath": "query.filter.updatedDate.$gt"
      },

      "pagination": {
        "type": "body",
        "pageSize": 100,
        "limitField": "query.paging.limit",
        "cursorField": "query.paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/contacts/v4/contacts",
          "bodyWrapper": "info"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/contacts/v4/contacts/{id}",
          "bodyWrapper": "info"
        },
        "delete": {
          "method": "DELETE",
          "url": "https://www.wixapis.com/contacts/v4/contacts/{id}"
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "contacts.csv",
        "format": "csv",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "flatten", "path": "info.name", "to": "" },
            { "op": "flatten", "path": "info.emails", "to": "emails" },
            { "op": "flatten", "path": "info.phones", "to": "phones" },
            { "op": "omit", "fields": ["info", "revision", "source", "lastActivity"] },
            { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/contacts/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 120,
        "debounceMs": 1000
      }
    },
    {
      "name": "blog-posts",
      "description": "Wix blog posts as Markdown files",
      "siteUrl": "YOUR_SITE_URL_HERE/blog",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/blog",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/blog/v3/posts/query",
        "body": {
          "query": {
            "paging": {
              "limit": 50
            }
          }
        },
        "dataPath": "$.posts",
        "updatedSinceBodyPath": "query.filter.updatedDate.$gt"
      },

      "pagination": {
        "type": "body",
        "pageSize": 50,
        "limitField": "query.paging.limit",
        "cursorField": "query.paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/blog/v3/draft-posts",
          "bodyWrapper": "draftPost"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/blog/v3/draft-posts/{id}",
          "bodyWrapper": "draftPost"
        },
        "delete": {
          "method": "DELETE",
          "url": "https://www.wixapis.com/blog/v3/posts/{id}"
        }
      },

      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "blog",
        "filename": "{slug|slugify}.md",
        "format": "md",
        "idField": "id",
        "contentField": "richContent",
        "transforms": {
          "pull": [
            { "op": "omit", "fields": ["coverMedia", "memberId", "hashtags", "commentingEnabled", "minutesToRead", "tagIds", "pricingPlanIds"] },
            { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/blog/{id}/edit" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 120,
        "debounceMs": 1000
      }
    },
    {
      "name": "products",
      "description": "Wix Store products as a CSV catalog",
      "siteUrl": "YOUR_SITE_URL_HERE/shop",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/store/products",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/stores/v3/products/search",
        "body": {
          "paging": {
            "limit": 100
          }
        },
        "dataPath": "$.products",
        "updatedSinceBodyPath": "search.filter.updatedDate.$gt"
      },

      "pagination": {
        "type": "body",
        "pageSize": 100,
        "limitField": "paging.limit",
        "cursorField": "paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/stores/v3/products",
          "bodyWrapper": "product"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/stores/v3/products/{id}",
          "bodyWrapper": "product",
          "bodyRootFields": ["revision"]
        },
        "delete": {
          "method": "DELETE",
          "url": "https://www.wixapis.com/stores/v3/products/{id}"
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "products.csv",
        "format": "csv",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "rename", "from": "actualPriceRange.minValue.amount", "to": "priceAmount" },
            { "op": "omit", "fields": ["actualPriceRange", "media", "options", "modifiers", "infoSections", "mainCategoryId", "physicalProperties", "handle", "variantsInfo", "additionalRibbons", "flattenOptions", "flattenModifiers", "variantSummary", "entityEventSequence", "numericId", "visibleInPos", "inventory"] },
            { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/store/products/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 120,
        "debounceMs": 1000
      }
    },
    {
      "name": "bookings",
      "description": "Wix Bookings services as JSON files",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/bookings/services",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/bookings/v2/services/query",
        "body": {
          "query": {
            "paging": {
              "limit": 100
            }
          }
        },
        "dataPath": "$.services"
      },

      "pagination": {
        "type": "body",
        "pageSize": 100,
        "limitField": "query.paging.limit",
        "cursorField": "query.paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/bookings/v2/services",
          "bodyWrapper": "service"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/bookings/v2/services/{id}",
          "bodyWrapper": "service"
        }
      },

      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "bookings",
        "filename": "{name|slugify}.json",
        "format": "json",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/bookings/services/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 300,
        "debounceMs": 500
      }
    },
    {
      "name": "collections",
      "description": "Wix CMS data collections catalog",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/wix-cms/data",

      "pull": {
        "method": "GET",
        "url": "https://www.wixapis.com/wix-data/v2/collections",
        "dataPath": "$.collections"
      },

      "push": {
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/wix-data/v2/collections/{id}"
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "collections.json",
        "format": "json",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/wix-cms/data/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "children": [
        {
          "name": "items",
          "description": "Items in this CMS collection",

          "pull": {
            "method": "POST",
            "url": "https://www.wixapis.com/wix-data/v2/items/query",
            "body": {
              "dataCollectionId": "{id}",
              "query": {
                "paging": {
                  "limit": 50
                }
              }
            },
            "dataPath": "$.dataItems"
          },

          "pagination": {
            "type": "body",
            "pageSize": 50,
            "limitField": "query.paging.limit",
            "cursorField": "query.paging.cursor",
            "nextCursorPath": "$.pagingMetadata.cursors.next"
          },

          "push": {
            "create": {
              "method": "POST",
              "url": "https://www.wixapis.com/wix-data/v2/items",
              "bodyWrapper": "dataItem"
            },
            "update": {
              "method": "PUT",
              "url": "https://www.wixapis.com/wix-data/v2/items/{id}",
              "bodyWrapper": "dataItem"
            },
            "delete": {
              "method": "DELETE",
              "url": "https://www.wixapis.com/wix-data/v2/items/{id}"
            }
          },

          "fileMapping": {
            "strategy": "collection",
            "directory": "cms/{displayName|slugify}",
            "filename": "items.csv",
            "format": "csv",
            "idField": "id",
            "transforms": {
              "pull": [
                { "op": "set", "field": "_url", "value": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/wix-cms/data/{collectionId}/{id}" }
              ],
              "push": [
                { "op": "omit", "fields": ["_url"] }
              ]
            }
          }
        }
      ],

      "sync": {
        "interval": 300,
        "debounceMs": 500
      }
    }
  ]
}

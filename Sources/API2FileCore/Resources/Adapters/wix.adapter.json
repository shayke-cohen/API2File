    {
      "name": "wix-music-podcasts",
      "description": "Audio assets stored in Media Manager for Wix Music and podcast playback",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/media-manager",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/site-media/v1/files/search",
        "type": "media",
        "body": {

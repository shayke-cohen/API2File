      }
    },
    {
      "name": "wix-video",
      "description": "Video assets stored in Media Manager for Wix Video content",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/media-manager",

      "pull": {

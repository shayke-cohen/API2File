      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/social-groups/v2/groups",
          "bodyWrapper": "group"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/social-groups/v2/groups/{id}",
          "bodyWrapper": "group"
        },
        "delete": {
          "method": "DELETE",
          "url": "https://www.wixapis.com/social-groups/v2/groups/{id}"
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "groups.csv",
        "format": "csv",
        "idField": "id",
        "pushMode": "custom",
        "transforms": {
          "pull": [
            { "op": "rename", "from": "settings.memberWelcomeMessage", "to": "welcomeMessage" },
            { "op": "omit", "fields": ["settings", "coverImage", "details", "createdBy", "recentActivityDate", "lastActivityDate", "pendingMembersCount"] }
          ],
          "push": [
            { "op": "set", "field": "title", "value": "{name}" },
            { "op": "set", "field": "createdBy.id", "value": "{ownerId}" },
            { "op": "set", "field": "createdBy.identityType", "value": "MEMBER" },
            { "op": "omit", "fields": ["id", "slug", "createdDate", "updatedDate", "memberCount", "membersCount", "welcomeMessage", "ownerId", "privacyLevel"] }
          ]
        }
      },

      "sync": {
        "interval": 300
      }
    },
    {
      "name": "comments",

    {
      "name": "bookings-services",
      "description": "Wix Bookings services as a CSV spreadsheet",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/bookings/services",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/bookings/v2/services/query",
        "body": {
          "query": {
            "paging": {
              "limit": 100
            }
          }
        },
        "dataPath": "$.services"
      },

      "pagination": {
        "type": "body",
        "pageSize": 100,
        "limitField": "query.paging.limit",
        "cursorField": "query.paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://www.wixapis.com/bookings/v2/services",
          "bodyWrapper": "service"
        },
        "update": {
          "method": "PATCH",
          "url": "https://www.wixapis.com/bookings/v2/services/{id}",
          "bodyWrapper": "service"
        },
        "delete": {
          "method": "DELETE",
          "url": "https://www.wixapis.com/bookings/v2/services/{id}"
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": "bookings",
        "filename": "services.csv",
        "format": "csv",
        "idField": "id",
        "pushMode": "custom",
        "transforms": {
          "pull": [
            { "op": "rename", "from": "defaultCapacity", "to": "capacity" },
            { "op": "rename", "from": "onlineBooking.enabled", "to": "onlineBookingEnabled" },
            { "op": "omit", "fields": ["onlineBooking", "staffMemberIds", "schedule", "payment", "form", "locations", "category", "media", "links", "sortOrder", "tagLine", "description", "bookingPolicy", "extendedFields"] }
          ],
          "push": [
            { "op": "omit", "fields": ["id", "type", "capacity", "onlineBookingEnabled", "createdDate", "updatedDate"] }
          ]
        }
      },

      "sync": {
        "interval": 120
      }
    },
    {
      "name": "bookings-appointments",
      "description": "Wix Bookings customer appointments and bookings",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/bookings/calendar",

      "pull": {
        "method": "POST",
        "url": "https://www.wixapis.com/bookings/v2/bookings/query",
        "body": {
          "query": {
            "paging": {
              "limit": 100
            }
          }
        },
        "dataPath": "$.bookings"
      },

      "pagination": {
        "type": "body",
        "pageSize": 100,
        "limitField": "query.paging.limit",
        "cursorField": "query.paging.cursor",
        "nextCursorPath": "$.pagingMetadata.cursors.next"
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": "bookings",
        "filename": "appointments.csv",
        "format": "csv",
        "idField": "id",
        "readOnly": true,
        "transforms": {
          "pull": [
            { "op": "rename", "from": "bookedEntity.title", "to": "serviceName" },
            { "op": "rename", "from": "contactDetails.firstName", "to": "guestFirstName" },
            { "op": "rename", "from": "contactDetails.lastName", "to": "guestLastName" },
            { "op": "rename", "from": "contactDetails.email", "to": "guestEmail" },
            { "op": "omit", "fields": ["bookedEntity", "contactDetails", "paymentDetails", "additionalFields", "extendedFields"] }
          ]
        }
      },

      "sync": {
        "interval": 120
      }
    },
    {
      "name": "groups",
      "description": "Wix Groups as a CSV spreadsheet",

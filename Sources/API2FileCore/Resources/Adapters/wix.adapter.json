        "filename": "comments.csv",
        "format": "csv",
        "idField": "id",
        "pushMode": "custom",
        "transforms": {
          "pull": [
            { "op": "rename", "from": "author.memberId", "to": "authorMemberId" },
            { "op": "rename", "from": "content.plainText", "to": "text" },
            { "op": "omit", "fields": ["author", "content", "voteSummary", "replyCount"] }
          ],
          "push": [
            { "op": "set", "field": "appId", "value": "14bcded7-0066-7c35-14d7-466cb3f09103" },
            { "op": "set", "field": "content.plainText", "value": "{text}" },
            { "op": "omit", "fields": ["id", "authorMemberId", "createdDate", "updatedDate", "status", "text"] }
          ]
        }
      },

      "sync": {
        "interval": 300
      }
    },
    {
      "name": "bookings",
      "description": "Wix Bookings services as JSON files",
      "dashboardUrl": "https://manage.wix.com/dashboard/YOUR_SITE_ID_HERE/bookings/services",

      "pull": {
        "method": "POST",

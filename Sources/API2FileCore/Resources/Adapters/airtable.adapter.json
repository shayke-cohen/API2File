{
  "service": "airtable",
  "displayName": "Airtable — Spreadsheet Database",
  "version": "1.0",
  "icon": "tablecells",
  "wizardDescription": "Records and bases as JSON files",
  "setupFields": [
    {
      "key": "base-id",
      "label": "Base ID",
      "placeholder": "appXXXXXXXXXX",
      "templateKey": "BASE_ID",
      "helpText": "Find in the Airtable URL: airtable.com/appXXX/..."
    },
    {
      "key": "table-name",
      "label": "Table Name",
      "placeholder": "My Table",
      "templateKey": "TABLE_NAME",
      "helpText": "The name of the table you want to sync"
    }
  ],

  "auth": {
    "type": "bearer",
    "keychainKey": "api2file.airtable.key",
    "setup": {
      "instructions": "1. Go to airtable.com/create/tokens and create a Personal Access Token. 2. Grant scopes: data.records:read, data.records:write, schema.bases:read. 3. Select the bases to sync. 4. After connecting, edit ~/API2File/airtable/.api2file/adapter.json — replace BASE_ID with your base ID (starts with 'app') and TABLE_NAME with your table name.",
      "url": "https://airtable.com/create/tokens"
    }
  },

  "globals": {
    "baseUrl": "https://api.airtable.com/v0",
    "headers": {
      "Content-Type": "application/json"
    }
  },

  "resources": [
    {
      "name": "records",
      "description": "Airtable records — one JSON file per record, edit and push back",

      "pull": {
        "method": "GET",
        "url": "https://api.airtable.com/v0/BASE_ID/TABLE_NAME",
        "dataPath": "$.records",
        "pagination": {
          "type": "offset",
          "pageSize": 100
        }
      },

      "push": {
        "create": {
          "method": "POST",
          "url": "https://api.airtable.com/v0/BASE_ID/TABLE_NAME",
          "bodyWrapper": "fields"
        },
        "update": {
          "method": "PATCH",
          "url": "https://api.airtable.com/v0/BASE_ID/TABLE_NAME/{id}",
          "bodyWrapper": "fields"
        },
        "delete": {
          "method": "DELETE",
          "url": "https://api.airtable.com/v0/BASE_ID/TABLE_NAME/{id}"
        }
      },

      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "records",
        "filename": "{id}.json",
        "format": "json",
        "idField": "id",
        "transforms": {
          "pull": [
            { "op": "omit", "fields": ["createdTime"] },
            { "op": "set", "field": "_url", "value": "https://airtable.com/BASE_ID/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 60,
        "debounceMs": 1000
      }
    },
    {
      "name": "bases",
      "description": "Catalog of your Airtable bases — reference list",

      "pull": {
        "method": "GET",
        "url": "https://api.airtable.com/v0/meta/bases",
        "dataPath": "$.bases",
        "pagination": {
          "type": "offset",
          "pageSize": 100
        }
      },

      "fileMapping": {
        "strategy": "collection",
        "directory": ".",
        "filename": "bases.json",
        "format": "json",
        "idField": "id",
        "readOnly": true,
        "transforms": {
          "pull": [
            { "op": "set", "field": "_url", "value": "https://airtable.com/{id}" }
          ]
        }
      },

      "sync": {
        "interval": 600,
        "debounceMs": 500
      }
    }
  ]
}

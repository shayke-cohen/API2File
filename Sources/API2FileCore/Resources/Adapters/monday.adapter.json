{
  "service": "monday",
  "displayName": "Monday.com",
  "version": "1.3",
  "icon": "calendar.badge.checkmark",
  "wizardDescription": "Boards and items as CSV files",
  "siteUrl": "https://monday.com",
  "dashboardUrl": "https://monday.com",

  "auth": {
    "type": "bearer",
    "keychainKey": "api2file.monday.api-key",
    "setup": {
      "instructions": "Go to monday.com → Avatar → Developers → My Access Tokens → Show/Generate",
      "url": "https://monday.com/apps/manage"
    }
  },

  "globals": {
    "baseUrl": "https://api.monday.com/v2",
    "method": "POST",
    "headers": {
      "Content-Type": "application/json"
    }
  },

  "resources": [
    {
      "name": "boards",
      "description": "Monday.com boards as read-only CSV snapshots",
      "dashboardUrl": "https://app.monday.com/boards",

      "pull": {
        "url": "https://api.monday.com/v2",
        "type": "graphql",
        "query": "{ boards(limit: 50) { id name description state board_kind groups { id title } items_page(limit: 200) { items { id name group { id title } column_values { id text type column { title } } } } } }",
        "dataPath": "$.data.boards"
      },

      "pagination": {
        "type": "cursor",
        "pageSize": 200,
        "queryTemplate": "{ boards(limit: 50) { id name description state board_kind groups { id title } items_page(limit: {limit}, after: \"{cursor}\") { cursor items { id name group { id title } column_values { id text type column { title } } } } } }",
        "nextCursorPath": "$.data.boards[0].items_page.cursor"
      },

      "fileMapping": {
        "strategy": "one-per-record",
        "directory": "boards",
        "filename": "{name|slugify}.csv",
        "format": "csv",
        "idField": "id",
        "readOnly": true,
        "transforms": {
          "pull": [
            { "op": "keyBy", "path": "column_values", "key": "column.title", "value": "text", "to": "columns" },
            { "op": "omit", "fields": ["column_values", "board_kind"] },
            { "op": "set", "field": "_url", "value": "https://app.monday.com/boards/{id}" }
          ],
          "push": [
            { "op": "omit", "fields": ["_url"] }
          ]
        }
      },

      "sync": {
        "interval": 60,
        "debounceMs": 500
      },

      "children": [
        {
          "name": "items",
          "description": "Monday board items as editable CSV rows",

          "pull": {
            "url": "https://api.monday.com/v2",
            "type": "graphql",
            "query": "{ boards(ids: [{id}]) { items_page(limit: 200) { items { id name board { id } group { id title } column_values { id text type column { title } } } } } }",
            "dataPath": "$.data.boards[0].items_page.items"
          },

          "push": {
            "create": {
              "url": "https://api.monday.com/v2",
              "type": "graphql",
              "bodyType": "monday-item-create"
            },
            "update": {
              "url": "https://api.monday.com/v2",
              "type": "graphql",
              "bodyType": "monday-item-update"
            },
            "delete": {
              "url": "https://api.monday.com/v2",
              "type": "graphql",
              "mutation": "mutation { delete_item(item_id: {id}) { id } }"
            }
          },

          "fileMapping": {
            "strategy": "collection",
            "directory": "boards/{name|slugify}",
            "filename": "items.csv",
            "format": "csv",
            "idField": "id",
            "transforms": {
              "pull": [
                { "op": "rename", "from": "board.id", "to": "boardId" },
                { "op": "keyBy", "path": "column_values", "key": "id", "value": "text", "to": "columns" },
                { "op": "omit", "fields": ["board", "column_values"] }
              ]
            }
          },

          "sync": {
            "interval": 60,
            "debounceMs": 500
          }
        }
      ]
    }
  ]
}
